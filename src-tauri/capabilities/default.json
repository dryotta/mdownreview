{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window — least-privilege permissions",
  "windows": ["main"],
  "permissions": [
    "core:app:default",
    "core:event:default",
    "core:menu:default",
    "core:window:default",
    "log:default",
    "dialog:allow-open",
    "clipboard-manager:allow-write-text",
    "opener:allow-open-url",
    "updater:default"
  ]
}
