{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mdownreview",
  "version": "0.3.4",
  "identifier": "com.mdownreview.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "mdownreview",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost data: blob:; media-src 'self' asset: https://asset.localhost blob:; frame-src 'self' asset: https://asset.localhost; font-src 'self' data:; connect-src ipc: http://ipc.localhost; object-src 'none'; base-uri 'self'; frame-ancestors 'none'",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis"],
    "createUpdaterArtifacts": "v1Compatible",
    "externalBin": ["binaries/mdownreview-cli"],
    "resources": ["dmg/README.txt"],
    "macOS": {
      "signingIdentity": "-"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "mdx"],
        "name": "Markdown File",
        "description": "Markdown document",
        "role": "Viewer"
      }
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "installer/installer-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/dryotta/mdownreview/releases/latest/download/latest.json"],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ1QUE3NDdDOTBENkMwNUIKUldSYndOYVFmSFNxMWJnWmZFbVZ2V3IyQXFhOGZnYjBHbVVZMWpmU0RKSUhLUlc5c3VsNEl3cDkK"
    }
  }
}
