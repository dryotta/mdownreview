{
  "name": "mdownreview",
  "private": true,
  "description": "Review AI Agent's work",
  "version": "0.3.4",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "stage:cli": "node scripts/stage-cli.mjs",
    "tauri:build": "node scripts/stage-cli.mjs --release && tauri build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --config=playwright.browser.config.ts",
    "test:e2e:native": "playwright test --config=playwright.native.config.ts",
    "test:e2e:native:build": "node scripts/stage-cli.mjs && cargo build --manifest-path src-tauri/Cargo.toml && npm run test:e2e:native",
    "lint": "eslint .",
    "bench:cli": "cd src-tauri && cargo bench",
    "bench:cli:script": "pwsh scripts/bench-cli.ps1"
  },
  "dependencies": {
    "@shikijs/rehype": "^4.0.2",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "katex": "^0.16.45",
    "mermaid": "^11.14.0",
    "papaparse": "^5.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shiki": "^4.0.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "js-yaml": "^4.1.1",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.3",
    "rehype-parse": "^9.0.1",
    "rehype-stringify": "^10.0.1",
    "typescript": "~5.8.3",
    "unified": "^11.0.5",
    "vite": "^7.0.4",
    "vitest": "^4.1.4"
  }
}
